<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApp.MainPage"
             Title="Lloydbe"
             BackgroundColor="#f8f4eb">
    <Grid>
        <WebView x:Name="AppWebView" />
        <Grid x:Name="LoadingOverlay" BackgroundColor="#f8f4eb">
            <VerticalStackLayout Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                <ActivityIndicator IsRunning="True" Color="#7d6aa8" WidthRequest="36" HeightRequest="36" />
                <Label Text="Loading Lloydbe..." TextColor="#4d4742" FontSize="14" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
